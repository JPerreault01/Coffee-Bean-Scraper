# (/data/* already covers these, listed explicitly to document intent.)
data/image_staging/
data/image_manifest.json

# Local design-QA screenshots (Stage 2 visual verification)
.tmp-shots/
# Stray empty artifact (literal bracket file from a shell mishap)
/\[

# Homepage image sources + converted WebP output (local-only; uploaded to the
# WP Media Library by hand, never served from the repo)
homepage-images/

# Backup artifacts (e.g. products.json.bak)
*.bak
