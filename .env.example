# .env.example
# Copy to /opt/.env on the VPS and fill in your real values.
# NEVER commit /opt/.env — it is gitignored.

# Amazon Product Advertising API (PA-API 5.0)
# Sign up: https://affiliate-program.amazon.com/assoc_credentials/home
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=

# Beehiiv email platform
# API key: https://app.beehiiv.com/settings/integrations/api
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# MiniMax API (for review generation)
# Sign up: https://www.minimaxi.com/
MINIMAX_API_KEY=

# Claude / Anthropic API (alternative for review generation)
# Sign up: https://console.anthropic.com/
CLAUDE_API_KEY=

# Reddit API (for training data pipeline)
# Create an app at https://www.reddit.com/prefs/apps (script type)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=coffee-pipeline/1.0

# YouTube Data API v3 (optional — enables channel-level video enumeration)
# Enable at https://console.cloud.google.com under YouTube Data API v3
YOUTUBE_API_KEY=
